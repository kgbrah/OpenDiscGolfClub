{
  "name": "open-disc-golf-club",
  "version": "0.1.0",
  "description": "Drop-in web components and setup tools for disc golf club websites.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kgbrah/OpenDiscGolfClub.git"
  },
  "homepage": "https://github.com/kgbrah/OpenDiscGolfClub#readme",
  "bugs": {
    "url": "https://github.com/kgbrah/OpenDiscGolfClub/issues"
  },
  "keywords": [
    "disc-golf",
    "club",
    "web-components",
    "custom-elements",
    "events",
    "tournaments"
  ],
  "sideEffects": [
    "dist/index.mjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "odgc": "./dist/cli.mjs",
    "open-disc-golf-club": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/cli.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/*.test.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "dev": "vite --host 0.0.0.0 --port 4174 examples/basic",
    "qa:demo": "playwright test tests/e2e/demo.spec.ts --browser=chromium --reporter=line"
  },
  "dependencies": {
    "ky": "^1.12.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "bun-types": "^1.3.14",
    "tsdown": "^0.17.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  }
}
